{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "–¶—Ц–ї—М",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#types"
    },
    {
      "include": "#attributes"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tsil",
          "match": "\\b(–і—Ц—П|—Б—В—А—Г–Ї—В—Г—А–∞|–∞–±–Њ|—Ц|–њ—Г—Б—В–Њ|—Б—В—А–Є–±–љ—Г—В–Є|–љ–µ|—В–∞–Ї|–љ—Ц|—Б—В–∞–ї–∞|—П–Ї—Й–Њ|–њ–Њ–Ї–Є|–≤–Ј—П—В–Є –Њ–Ј–љ–∞—З–µ–љ–љ—П|–≤–Ј—П—В–Є –±—Ц–±|–≤–Ј—П—В–Є|—П–Ї|–≤–µ—А–љ—Г—В–Є|—Ц–љ–∞–Ї—И–µ|–Ј–Њ–≤–љ—Ц—И–љ—П|–≤–љ—Г—В—А—Ц—И–љ—П|–њ—А–Њ—Б—В—Ц—А|–Ј–Љ—Ц–љ–љ–∞|—Ж—Ц–ї—М)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.tsil",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.tsil",
          "match": "\\\\."
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.numeric.tsil",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.tsil",
          "match": "\\b(–Ї–і|—Ж8|—Ж16|—Ж32|—Ж64|—Ж—Ц–ї–µ|–њ8|–њ16|–њ32|–њ64|–њ—А–Є—А–Њ–і–љ–µ|—О8|–≤–Љ—Ц—Б—В|–ї–Њ–≥—Ц—З–љ–µ|–∞–і—А–µ—Б–∞|–њ–∞–Љ Љ—П—В—М|–љ–µ–≤—Ц–і–Њ–Љ–∞_–∞–і—А–µ—Б–∞|–љ–µ–≤—Ц–і–Њ–Љ–∞_–њ–∞–Љ Љ—П—В—М|–і32|–і64|–љ—Ц—Й–Њ)\\b"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.tsil",
          "match": "//.*$"
        },
        {
          "name": "comment.block.tsil",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "attributes": {
      "name": "entity.other.attribute-name.tsil",
      "match": "\\\\[a-zA-Z–∞-—П–Р-–ѓ—Ц–Ж—Ч–З—Ф–Д“С“Р_][a-zA-Z–∞-—П–Р-–ѓ—Ц–Ж—Ч–З—Ф–Д“С“Р0-9_]*"
    }
  },
  "scopeName": "source.—Ж—Ц–ї—М"
}